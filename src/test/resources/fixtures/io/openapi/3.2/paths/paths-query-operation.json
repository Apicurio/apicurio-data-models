{
  "openapi": "3.2.0",
  "paths": {
    "/resources": {
      "summary": "Resources",
      "get": {
        "summary": "List resources",
        "operationId": "listResources"
      },
      "query": {
        "summary": "Query resources",
        "description": "Safely query resources using a JSON request body",
        "operationId": "queryResources",
        "requestBody": {
          "description": "Query parameters",
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "filter": {
                    "type": "string"
                  },
                  "limit": {
                    "type": "integer"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful query response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object"
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
