{
    "openapi": "3.2.0",
    "info": {
        "title": "Example Mutual Exclusivity Test",
        "version": "1.0.0"
    },
    "paths": {},
    "components": {
        "examples": {
            "ValidDataValue": {
                "summary": "Valid example with dataValue only",
                "dataValue": { "name": "Fido" }
            },
            "ValidSerializedValue": {
                "summary": "Valid example with serializedValue only",
                "serializedValue": "<pet><name>Fido</name></pet>"
            },
            "InvalidDataValueAndValue": {
                "summary": "Invalid: both dataValue and value",
                "dataValue": { "name": "Fido" },
                "value": { "name": "Fido" }
            },
            "InvalidSerializedAndValue": {
                "summary": "Invalid: serializedValue and value",
                "serializedValue": "<pet/>",
                "value": { "name": "Buddy" }
            },
            "InvalidSerializedAndExternal": {
                "summary": "Invalid: serializedValue and externalValue",
                "serializedValue": "<pet/>",
                "externalValue": "http://example.com/pet.xml"
            }
        }
    }
}
