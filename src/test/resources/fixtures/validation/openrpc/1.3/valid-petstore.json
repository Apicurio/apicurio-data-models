{
  "openrpc": "1.3.2",
  "info": {
    "title": "Petstore",
    "description": "A sample API for managing pets using JSON-RPC.",
    "version": "1.0.0",
    "contact": {
      "name": "API Support",
      "url": "https://example.com/support",
      "email": "support@example.com"
    },
    "license": {
      "name": "Apache 2.0",
      "url": "https://www.apache.org/licenses/LICENSE-2.0"
    }
  },
  "servers": [
    {
      "name": "Production",
      "url": "https://api.example.com/jsonrpc",
      "summary": "Production server",
      "description": "The main production JSON-RPC endpoint."
    }
  ],
  "methods": [
    {
      "name": "listPets",
      "summary": "List all pets",
      "description": "Returns all pets from the system.",
      "params": [
        {
          "name": "limit",
          "description": "Maximum number of pets to return",
          "required": false,
          "schema": {
            "type": "integer",
            "minimum": 1,
            "maximum": 100
          }
        }
      ],
      "result": {
        "name": "pets",
        "description": "A list of pets",
        "schema": {
          "type": "array",
          "items": {
            "$ref": "#/components/schemas/Pet"
          }
        }
      },
      "tags": [
        {
          "name": "pets"
        }
      ]
    },
    {
      "name": "getPet",
      "summary": "Get a pet by ID",
      "params": [
        {
          "name": "petId",
          "description": "The ID of the pet to retrieve",
          "required": true,
          "schema": {
            "type": "integer"
          }
        }
      ],
      "result": {
        "name": "pet",
        "description": "The requested pet",
        "schema": {
          "$ref": "#/components/schemas/Pet"
        }
      },
      "errors": [
        {
          "code": -32001,
          "message": "Pet not found"
        }
      ],
      "tags": [
        {
          "name": "pets"
        }
      ]
    }
  ],
  "components": {
    "schemas": {
      "Pet": {
        "type": "object",
        "required": ["id", "name"],
        "properties": {
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "tag": {
            "type": "string"
          }
        }
      }
    }
  },
  "externalDocs": {
    "description": "Full API documentation",
    "url": "https://example.com/docs"
  }
}
