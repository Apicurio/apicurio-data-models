{
  "openapi": "3.0.2",
  "info": {
    "title": "Test API",
    "version": "1.0.0"
  },
  "paths": {
    "/widgets": {
      "post": {
        "summary": "Create a widget",
        "responses": {
          "201": {
            "description": "Created"
          }
        },
        "callbacks": {
          "onCreated": {
            "$ref": "#/components/callbacks/WidgetEvent"
          }
        }
      }
    },
    "/gadgets": {
      "post": {
        "summary": "Create a gadget",
        "responses": {
          "201": {
            "description": "Created"
          }
        },
        "callbacks": {
          "onCreated": {
            "$ref": "#/components/callbacks/WidgetEvent"
          }
        }
      }
    }
  },
  "components": {
    "callbacks": {
      "WidgetEvent": {
        "{$request.body#/callbackUrl}": {
          "post": {
            "summary": "Widget event notification",
            "responses": {
              "200": {
                "description": "Callback received"
              }
            }
          }
        }
      },
      "GadgetEvent": {
        "{$request.body#/callbackUrl}": {
          "post": {
            "summary": "Gadget event notification",
            "responses": {
              "200": {
                "description": "Callback received"
              }
            }
          }
        }
      }
    }
  }
}
