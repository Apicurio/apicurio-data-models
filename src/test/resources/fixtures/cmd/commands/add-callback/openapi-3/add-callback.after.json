{
  "openapi": "3.0.0",
  "paths": {
    "/foo": {
      "get": {
        "summary": "Get Foo",
        "operationId": "getFoo",
        "responses": {
          "200": {
            "description": "Successful response"
          }
        },
        "callbacks": {
          "onFooEvent": {
            "{$request.body#/callbackUrl}": {
              "post": {
                "summary": "Foo Event Callback",
                "responses": {
                  "200": {
                    "description": "Callback processed"
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
