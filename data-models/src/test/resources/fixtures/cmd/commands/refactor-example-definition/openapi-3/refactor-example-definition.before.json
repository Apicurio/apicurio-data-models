{
  "openapi": "3.0.2",
  "info": {
    "title": "Test API",
    "version": "1.0.0"
  },
  "paths": {
    "/widgets": {
      "get": {
        "summary": "List widgets",
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object"
                  }
                },
                "examples": {
                  "example1": {
                    "$ref": "#/components/examples/WidgetExample"
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Create a widget",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              },
              "examples": {
                "example1": {
                  "$ref": "#/components/examples/WidgetExample"
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created"
          }
        }
      }
    }
  },
  "components": {
    "examples": {
      "WidgetExample": {
        "summary": "A sample widget",
        "value": {
          "id": 1,
          "name": "Sprocket"
        }
      },
      "GadgetExample": {
        "summary": "A sample gadget",
        "value": {
          "id": 2,
          "name": "Gizmo"
        }
      }
    }
  }
}
