{
  "openrpc": "1.3.2",
  "info": {
    "title": "Test API",
    "version": "1.0.0"
  },
  "methods": [
    {
      "name": "getWidget",
      "params": [
        {
          "name": "id",
          "schema": { "type": "integer" }
        }
      ],
      "result": {
        "name": "widget",
        "schema": { "$ref": "#/components/schemas/Widget" }
      },
      "examples": [
        {
          "name": "widgetExamplePairing",
          "params": [
            { "$ref": "#/components/examples/WidgetExample" }
          ],
          "result": {
            "$ref": "#/components/examples/WidgetExample"
          }
        }
      ]
    }
  ],
  "components": {
    "examples": {
      "WidgetExample": {
        "name": "WidgetExample",
        "summary": "A sample widget",
        "value": {
          "id": 1,
          "name": "Sprocket"
        }
      },
      "GadgetExample": {
        "name": "GadgetExample",
        "summary": "A sample gadget",
        "value": {
          "id": 2,
          "name": "Gizmo"
        }
      }
    }
  }
}
