{
  "openapi": "3.2.0",
  "paths": {
    "/resources/{id}": {
      "summary": "Resource by ID",
      "get": {
        "summary": "Get a resource"
      },
      "put": {
        "summary": "Update a resource"
      },
      "delete": {
        "summary": "Delete a resource"
      },
      "additionalOperations": {
        "copy": {
          "summary": "Copy a resource",
          "operationId": "copyResource"
        },
        "link": {
          "summary": "Link a resource",
          "operationId": "linkResource",
          "requestBody": {
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "targetId": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
