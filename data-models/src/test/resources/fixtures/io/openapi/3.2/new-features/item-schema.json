{
  "openapi": "3.2.0",
  "paths": {
    "/events": {
      "get": {
        "summary": "Stream events",
        "responses": {
          "200": {
            "description": "Event stream",
            "content": {
              "text/event-stream": {
                "schema": {
                  "type": "string"
                },
                "itemSchema": {
                  "type": "object",
                  "properties": {
                    "event": {
                      "type": "string"
                    },
                    "data": {
                      "type": "object"
                    },
                    "id": {
                      "type": "string"
                    }
                  }
                }
              },
              "application/jsonl": {
                "itemSchema": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "integer"
                    },
                    "message": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
