{
  "openapi": "3.0.2",
  "info": {
    "title": "Test API",
    "version": "1.0.0"
  },
  "paths": {
    "/widgets": {
      "get": {
        "summary": "List widgets",
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/NewName"
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Create a widget",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/NewName"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created"
          }
        }
      }
    },
    "/widgets/{widgetId}": {
      "get": {
        "summary": "Get a widget",
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NewName"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "OtherSchema": {
        "type": "object",
        "properties": {
          "widget": {
            "$ref": "#/components/schemas/NewName"
          }
        }
      },
      "NewName": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          }
        }
      }
    }
  }
}
