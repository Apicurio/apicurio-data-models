{
    "openapi": "3.1.0",
    "info": {
        "title": "Discriminator Base Schema Test",
        "version": "1.0.0"
    },
    "paths": {
        "/pets": {
            "get": {
                "summary": "List all pets",
                "responses": {
                    "200": {
                        "description": "A list of pets.",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "oneOf": [
                                        { "$ref": "#/components/schemas/Cat" },
                                        { "$ref": "#/components/schemas/Dog" }
                                    ]
                                }
                            }
                        }
                    }
                }
            }
        },
        "/sch-002": {
            "get": {
                "summary": "Invalid discriminator usage",
                "responses": {
                    "200": {
                        "description": "A response with an invalid discriminator.",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "name": {}
                                    },
                                    "discriminator": {
                                        "propertyName": "name"
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    },
    "components": {
        "schemas": {
            "Pet": {
                "type": "object",
                "required": [ "petType" ],
                "properties": {
                    "petType": {
                        "type": "string"
                    }
                },
                "discriminator": {
                    "propertyName": "petType"
                }
            },
            "Cat": {
                "allOf": [
                    { "$ref": "#/components/schemas/Pet" },
                    {
                        "type": "object",
                        "properties": {
                            "huntingSkill": {
                                "type": "string"
                            }
                        }
                    }
                ]
            },
            "Dog": {
                "allOf": [
                    { "$ref": "#/components/schemas/Pet" },
                    {
                        "type": "object",
                        "properties": {
                            "breed": {
                                "type": "string"
                            }
                        }
                    }
                ]
            }
        }
    }
}
