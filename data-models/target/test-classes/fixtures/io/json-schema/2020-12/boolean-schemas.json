{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://example.com/boolean-schemas-2020-12",
    "$comment": "Tests boolean values in all schema-accepting positions for 2020-12",
    "title": "Boolean Schema Coverage",
    "description": "Exercises all boolean|JSchema union types in 2020-12",
    "type": "object",
    "$defs": {
        "alwaysTrue": true,
        "alwaysFalse": false,
        "normalSchema": {
            "type": "string"
        }
    },
    "properties": {
        "name": {
            "type": "string"
        },
        "anything": true,
        "nothing": false
    },
    "patternProperties": {
        "^x-": true,
        "^y-": false
    },
    "additionalProperties": false,
    "not": true,
    "contains": false,
    "propertyNames": true,
    "if": true,
    "then": false,
    "else": true,
    "contentSchema": false,
    "unevaluatedItems": true,
    "unevaluatedProperties": false,
    "dependentSchemas": {
        "name": true,
        "age": false,
        "email": {
            "type": "object"
        }
    },
    "items": true,
    "prefixItems": [
        true,
        {
            "type": "string"
        },
        false
    ],
    "allOf": [
        true,
        {
            "type": "object"
        },
        false
    ],
    "anyOf": [
        false,
        {
            "type": "string"
        }
    ],
    "oneOf": [
        true,
        {
            "type": "number"
        }
    ]
}
